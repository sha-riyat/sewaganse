---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  id: string;
  thumb: ImageMetadata;
  title: { fr: string; en: string };
  services: { fr: string; en: string };
}

const { id, thumb, title, services } = Astro.props;
---

<a href={`/projects/${id}`} class="project-card">
  <div class="project-card-image">
    <Image src={thumb} alt="" />
  </div>
  <div class="project-card-info">
    <h2 class="project-card-title">
      <span class="lang-fr">{title.fr}</span>
      <span class="lang-en">{title.en}</span>
    </h2>
    <p class="project-card-services">
      <span class="lang-fr">{services.fr}</span>
      <span class="lang-en">{services.en}</span>
    </p>
  </div>
</a>

<style>
  .project-card {
    display: block;
    text-decoration: none;
  }

  .project-card-image {
    margin-bottom: var(--spacing-10);
    overflow: hidden; /* Important pour contenir le zoom */
  }

  .project-card-image :global(img) {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s ease; /* Animation fluide */
  }

  .project-card:hover .project-card-image :global(img) {
    transform: scale(1.05); /* Zoom de 5% */
  }

  .project-card-title {
    font-size: var(--text-heading);
    line-height: var(--leading-heading);
    letter-spacing: var(--tracking-heading);
    font-weight: 300;
    margin-bottom: var(--spacing-8);
  }

  .project-card-services {
    font-size: var(--text-body);
    line-height: var(--leading-body);
    letter-spacing: var(--tracking-body);
    font-weight: 300;
    color: var(--color-muted);
  }
</style>
