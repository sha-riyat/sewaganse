---
import { Image } from 'astro:assets';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { projects } from '../../data/projects';
import '../../styles/global.css';

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<!doctype html>
<html lang="fr" data-lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{project.title.en} — Shariyat Ganse</title>
    <script is:inline>
      (function () {
        var html = document.documentElement;
        var saved = localStorage.getItem('lang');
        if (saved === 'en' || saved === 'fr') {
          html.lang = saved;
          html.dataset.lang = saved;
        }
      })();
    </script>
  </head>
  <body>
    <Header />
    <main>
      <article class="project-detail">
        <h1 class="project-detail-title">
          <span class="lang-fr">{project.title.fr}</span>
          <span class="lang-en">{project.title.en}</span>
        </h1>
        <div class="project-detail-meta">
          <p class="project-detail-client">
            <span class="lang-fr">Client</span>
            <span class="lang-en">Client</span>
            <span class="meta-sep">&thinsp;:</span>
            <span class="lang-fr">{project.client.fr}</span>
            <span class="lang-en">{project.client.en}</span>
          </p>
          <p class="project-detail-services">
            <span class="lang-fr">Services</span>
            <span class="lang-en">Services</span>
            <span class="meta-sep">&thinsp;:</span>
            <span class="lang-fr">{project.services.fr}</span>
            <span class="lang-en">{project.services.en}</span>
          </p>
          <p class="project-detail-description">
            <span class="lang-fr">{project.description.fr}</span>
            <span class="lang-en">{project.description.en}</span>
          </p>
        </div>
        <div class="project-detail-hero">
          <Image src={project.hero} alt="" />
        </div>
        {project.images.length > 1 && (
          <div class="project-detail-gallery">
            {project.images.slice(1).map((img) => (
              <div class="project-detail-gallery-image">
                <Image src={img} alt="" />
              </div>
            ))}
          </div>
        )}
      </article>
    </main>
    <Footer />
    <script src="../../scripts/lang.js"></script>
  </body>
</html>

<style is:global>
  .project-detail {
    padding: var(--spacing-60) var(--spacing-20) var(--spacing-80);
  }

  .project-detail-title {
    font-size: var(--text-display);
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-display);
    font-weight: 300;
    margin-bottom: var(--spacing-20);
  }

  .project-detail-meta {
    margin-bottom: var(--spacing-30);
    font-size: var(--text-body);
    line-height: var(--leading-body);
    letter-spacing: var(--tracking-body);
  }

  .project-detail-meta p {
    margin-bottom: var(--spacing-5);
  }

  .meta-sep {
    margin-right: var(--spacing-5);
  }

  .project-detail-client span:last-child,
  .project-detail-services span:last-child {
    font-weight: 400;
  }

  .project-detail-description {
    margin-top: var(--spacing-20);
    max-width: 640px;
  }

  .project-detail-hero {
    margin-bottom: var(--spacing-20);
  }

  .project-detail-hero :global(img),
  .project-detail-gallery-image :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  .project-detail-gallery {
    display: grid;
    gap: var(--spacing-20);
  }
</style>
